# 股票分析项目 - 环境变量配置
# 复制为 .env 并填写你的API密钥

# ============================================
# 飞书推送配置（必需）
# ============================================
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的token

# ============================================
# Tavily 新闻搜索（专业版推荐）
# 免费额度: 1000次/月
# 获取: https://tavily.com
# ============================================
TAVILY_API_KEY=tvly-你的密钥

# ============================================
# AI分析配置（DeepSeek推荐 - 便宜且中文好）
# 获取: https://platform.deepseek.com
# 新用户有5元免费额度
# ============================================
OPENAI_API_KEY=sk-你的DeepSeek密钥
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# 备选: OpenAI（更稳定但略贵）
# OPENAI_API_KEY=sk-你的OpenAI密钥
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# Tushare 数据（可选，增强数据质量）
# 获取: https://tushare.pro
# ============================================
# TUSHARE_TOKEN=你的tushare token

# ============================================
# 分析参数配置
# ============================================
# 默认分析股票（逗号分隔）
DEFAULT_STOCKS=000001.SZ,000002.SZ,600519.SH

# 是否启用回测验证
ENABLE_BACKTEST=true

# 新闻搜索最近几天
NEWS_MAX_AGE_DAYS=3

# 推送时间（盘前8:50）
SCHEDULE_TIME=50 8 * * 1-5
