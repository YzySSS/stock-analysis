# 股票分析项目定时任务配置
# =========================
# 使用说明:
# 1. 确保 env_config.sh 中的配置正确
# 2. 将此文件内容添加到 crontab: crontab -e
# 3. 所有任务都会自动加载环境变量

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# 股票分析定时任务
# -----------------

# 盘前分析 - 每天 8:50 (周一到周五)
50 8 * * 1-5 /root/.openclaw/workspace/股票分析项目/run_analysis.sh premarket >> /tmp/cron_premarket.log 2>&1

# 盘中简报 - 每天 12:30 (周一到周五)
30 12 * * 1-5 /root/.openclaw/workspace/股票分析项目/run_analysis.sh intraday >> /tmp/cron_intraday.log 2>&1

# 收盘数据更新 - 每天 15:35 (周一到周五)
35 15 * * 1-5 /root/.openclaw/workspace/股票分析项目/run_analysis.sh daily >> /tmp/cron_daily.log 2>&1

# 盘后复盘 - 每天 15:50 (周一到周五)
50 15 * * 1-5 /root/.openclaw/workspace/股票分析项目/run_analysis.sh postmarket >> /tmp/cron_postmarket.log 2>&1

# MySQL历史数据每日更新 - 每天 22:00 (周一到周五)
# 自动检查是否为交易日，非交易日自动跳过
# 更新完成后自动输出结构化报告
0 22 * * 1-5 cd /root/.openclaw/workspace/股票分析项目 && python3 daily_update_mysql.py >> /tmp/cron_mysql_daily.log 2>&1

# 每日舆情数据更新 - 每天 22:30 (周一到周五)
# 使用AkShare免费获取新闻，AI分析后存入MySQL
30 22 * * 1-5 cd /root/.openclaw/workspace/股票分析项目 && python3 sentiment_daily_update.py >> /tmp/cron_sentiment.log 2>&1
